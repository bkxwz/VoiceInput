<Window x:Class="VoiceInput.UI.RecordingOverlay"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        Height="56" Width="400">
    <Grid>
        <Border CornerRadius="28" Background="#CC000000" Opacity="0.8" Height="56">
            <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Margin="10">
                <Grid Width="44">
                    <!-- Waveform will be drawn here dynamically -->
                </Grid>
                <TextBlock Text="Recording..." FontSize="16" Foreground="White" VerticalAlignment="Center" Margin="10,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>